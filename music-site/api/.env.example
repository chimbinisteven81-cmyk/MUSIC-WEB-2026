# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=smads_african_hits

# ── App ───────────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:5000
SITE_URL=http://localhost:5000
SECRET_KEY=change-me-to-a-long-random-string-minimum-32-chars
ADMIN_EMAIL=admin@smadsafricanhits.com

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Used for: contact form replies, email verification, password reset, security alerts
#
# Gmail example (use an App Password, not your real password):
#   1. Enable 2FA on your Google account
#   2. Go to myaccount.google.com/apppasswords
#   3. Generate an App Password for "Mail"
#   4. Paste it as ALERT_SMTP_PASS below
#
ALERT_EMAIL_TO=your@email.com          # where contact messages are forwarded
ALERT_EMAIL_FROM=noreply@smadsafricanhits.com
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=your@gmail.com
ALERT_SMTP_PASS=your-app-password-here

# ── Production only ───────────────────────────────────────────────────────────
# FLASK_ENV=production
# HTTPS_ENABLED=true
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# SESSION_INACTIVITY_MINUTES=60
